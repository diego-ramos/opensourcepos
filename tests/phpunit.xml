<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.0/phpunit.xsd"
    bootstrap="../vendor/codeigniter4/framework/system/Test/bootstrap.php"
    backupGlobals="false"
    beStrictAboutOutputDuringTests="true"
    colors="true"
    columns="max"
    cacheDirectory="../build/.phpunit.cache">
    <testsuites>
        <testsuite name="Helpers">
            <directory>helpers</directory>
        </testsuite>
        <testsuite name="App">
            <directory>app</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory suffix=".php">../app</directory>
        </include>
        <exclude>
            <directory suffix=".php">../app/Views</directory>
            <file>../app/Config/Routes.php</file>
        </exclude>
    </source>
    <php>
        <server name="app.baseURL" value="http://example.com/"/>
        <server name="CODEIGNITER_SCREAM_DEPRECATIONS" value="0"/>
        <const name="HOMEPATH" value="../"/>
        <const name="CONFIGPATH" value="../app/Config/"/>
        <const name="PUBLICPATH" value="../public/"/>
        <!-- Test database (ospos_test) -->
        <env name="database.tests.hostname" value="localhost"/>
        <env name="database.tests.database" value="ospos_test"/>
        <env name="database.tests.username" value="ospdbuser"/>
        <env name="database.tests.password" value="posuser2025*"/>
        <env name="database.tests.DBDriver" value="MySQLi"/>
        <env name="database.tests.DBPrefix" value="ospos_"/>
        <env name="database.tests.port" value="3306"/>
    </php>
</phpunit>
